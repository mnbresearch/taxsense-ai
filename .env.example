# ---- LLM (conversational intake) ----
# Default provider: Groq. Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback provider: Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Force a provider: groq | anthropic | mock  (mock = zero-key demo mode)
INTAKE_PROVIDER=

# ---- Supabase (auth + storage of profiles) ----
# Create a free project at https://supabase.com, then Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, NEVER exposed to the client (admin dashboard)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Admin ----
# Comma-separated emails allowed into /admin
ADMIN_EMAILS=mridulnanda2004@gmail.com
